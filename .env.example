# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=

# Admin Authentication
ADMIN_SECRET=

# Database Configuration
# Required for PostgreSQL connection (e.g., Supabase, Neon, Cloud SQL)
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# Marketcheck API
MARKETCHECK_API_KEY=
MARKETCHECK_API_SECRET=

# Telegram Integration (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 700Credit Configuration
CREDIT_700_API_KEY=
CREDIT_700_API_URL=https://api.700credit.com/v1
CREDIT_700_SANDBOX=true

# Twilio Configuration (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP Configuration (Email via Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Google Analytics
VITE_GA_ID=
