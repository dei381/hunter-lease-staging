generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VehicleCache {
  id              String          @id @default(uuid())
  vin             String?         @unique
  make            String
  model           String
  trim            String
  year            Int
  msrpCents       Int
  bodyStyle       String?
  features        String
  isActive        Boolean         @default(true)
  verifiedByAdmin Boolean         @default(false)
  verifiedAt      DateTime?
  updatedAt       DateTime        @updatedAt
  quoteSnapshots  QuoteSnapshot[]

  @@index([make, model, year, trim, isActive])
}

model RegionalTaxFeeCache {
  id                   String   @id @default(uuid())
  zipCode              String   @unique
  state                String
  county               String?
  salesTaxRate         Decimal
  estimatedDmvFeeCents Int
  updatedAt            DateTime @updatedAt

  @@index([zipCode])
}

model GlobalEstimationPolicy {
  id                   String   @id
  fallbackSalesTaxRate Decimal
  fallbackDmvFeeCents  Int
  fallbackDocFeeCents  Int
  updatedAt            DateTime @updatedAt
}

model CatalogDefaultScenario {
  id                   String   @id
  quoteType            String
  term                 Int
  mileage              Int?
  dueAtSigningCents    Int?
  downPaymentCents     Int?
  uxTier               String
  assumeFirstTimeBuyer Boolean  @default(false)
  updatedAt            DateTime @updatedAt
}

model Lender {
  id                       String                      @id @default(uuid())
  name                     String                      @unique
  isCaptive                Boolean                     @default(false)
  isFirstTimeBuyerFriendly Boolean                     @default(false)
  lenderType               String                      @default("NATIONAL_BANK")
  priority                 Int                         @default(0)
  isActive                 Boolean                     @default(true)
  createdAt                DateTime                    @default(now())
  bankPrograms             BankProgram[]
  dealRecords              DealRecord[]
  financePrograms          FinanceProgram[]
  leasePrograms            LeaseProgram[]
  eligibilityRules         LenderEligibilityRule[]
  feePolicies              LenderFeePolicy[]
  programAvailabilities    LenderProgramAvailability[]
  tierMappings             LenderTierMapping[]
  quotes                   Quote[]
  quoteSnapshots           QuoteSnapshot[]

  @@index([isActive, priority])
}

model LenderProgramAvailability {
  id                String @id @default(uuid())
  lenderId          String
  make              String
  dealApplicability String
  lender            Lender @relation(fields: [lenderId], references: [id], onDelete: Cascade)

  @@unique([lenderId, make, dealApplicability])
}

model LenderEligibilityRule {
  id                        String  @id @default(uuid())
  lenderId                  String
  make                      String
  model                     String  @default("ALL")
  dealApplicability         String
  allowFirstTimeBuyer       Boolean @default(false)
  allowWithCoSigner         Boolean @default(true)
  requiresEstablishedCredit Boolean @default(true)
  minUxTierRequired         String
  lender                    Lender  @relation(fields: [lenderId], references: [id], onDelete: Cascade)

  @@unique([lenderId, make, model, dealApplicability])
}

model LenderTierMapping {
  id                 String  @id @default(uuid())
  lenderId           String
  uxTier             String
  internalLenderTier String
  mfMarkup           Decimal
  aprMarkup          Decimal
  lender             Lender  @relation(fields: [lenderId], references: [id], onDelete: Cascade)

  @@unique([lenderId, uxTier])
}

model LenderFeePolicy {
  id                  String               @id @default(uuid())
  lenderId            String
  quoteType           String
  acquisitionFeeCents Int
  docFeeLimitCents    Int
  maxLtvPercentage    Decimal
  rollabilityRules    FeeRollabilityRule[]
  lender              Lender               @relation(fields: [lenderId], references: [id], onDelete: Cascade)

  @@unique([lenderId, quoteType])
}

model FeeRollabilityRule {
  id                String          @id @default(uuid())
  lenderFeePolicyId String
  tierScope         String          @default("ALL")
  canRollAcqFee     Boolean         @default(true)
  canRollDocFee     Boolean         @default(false)
  canRollTaxes      Boolean         @default(false)
  feePolicy         LenderFeePolicy @relation(fields: [lenderFeePolicyId], references: [id], onDelete: Cascade)

  @@unique([lenderFeePolicyId, tierScope])
}

model LeaseProgram {
  id                 String    @id @default(uuid())
  lenderId           String
  make               String
  model              String
  trim               String
  year               Int
  term               Int
  mileage            Int
  internalLenderTier String
  buyRateMf          Decimal
  residualPercentage Decimal
  isActive           Boolean   @default(true)
  status             String    @default("PUBLISHED")
  effectiveFrom      DateTime?
  effectiveTo        DateTime?
  lender             Lender    @relation(fields: [lenderId], references: [id], onDelete: Cascade)

  @@unique([lenderId, make, model, trim, year, term, mileage, internalLenderTier])
  @@index([make, model, year, trim, isActive])
}

model FinanceProgram {
  id                 String    @id @default(uuid())
  lenderId           String
  make               String
  model              String
  trim               String
  year               Int
  term               Int
  internalLenderTier String
  buyRateApr         Decimal
  isActive           Boolean   @default(true)
  status             String    @default("PUBLISHED")
  effectiveFrom      DateTime?
  effectiveTo        DateTime?
  lender             Lender    @relation(fields: [lenderId], references: [id], onDelete: Cascade)

  @@unique([lenderId, make, model, trim, year, term, internalLenderTier])
  @@index([make, model, year, trim, isActive])
}

model OemIncentiveProgram {
  id                String    @id @default(uuid())
  seedKey           String?   @unique
  name              String
  amountCents       Int
  type              String
  dealApplicability String
  isTaxableCa       Boolean   @default(true)
  exclusiveGroupId  String?
  make              String
  model             String?
  trim              String?
  trimGroup         String?
  stackable         Boolean   @default(true)
  eligibilityRules  Json?
  verifiedByAdmin   Boolean   @default(false)
  verifiedAt        DateTime?
  isActive          Boolean   @default(true)
  status            String    @default("PUBLISHED")
  effectiveFrom     DateTime?
  effectiveTo       DateTime?

  @@index([make, model, isActive])
}

model HunterDiscountPolicy {
  id              String   @id @default(uuid())
  seedKey         String?  @unique
  name            String
  discountType    String
  flatAmountCents Int?
  percentageMsrp  Decimal?
  scopeLevel      String
  targetValue     String?
  isActive        Boolean  @default(true)
}

model QuoteSnapshot {
  id                       String       @id @default(uuid())
  vehicleId                String
  surface                  String
  quoteType                String
  quoteStatus              String
  confidenceLevel          String
  usedFallbackFlags        String       @default("[]")
  manualReviewFlags        String       @default("[]")
  isDefaultCatalogScenario Boolean      @default(false)
  monthlyPaymentCents      Int
  effectiveDasOrDownCents  Int
  totalSavingsCents        Int
  lenderId                 String?
  auditPayload             String
  createdAt                DateTime     @default(now())
  lender                   Lender?      @relation(fields: [lenderId], references: [id])
  vehicle                  VehicleCache @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([isDefaultCatalogScenario, vehicleId, quoteType])
  @@index([vehicleId, surface, quoteType, quoteStatus])
  @@index([surface, monthlyPaymentCents, effectiveDasOrDownCents])
  @@index([createdAt])
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  password         String?  @default("temporary-password")
  role             String   @default("user")
  status           String   @default("active")
  dealerPartnerId  String?
  createdAt        DateTime @default(now())
  leads            Lead[]   @relation("AssignedLeads")

  @@index([role])
}

model Lead {
  id               String      @id @default(uuid())
  email            String?
  phone            String?
  name             String?
  clientName       String?
  clientPhone      String?
  clientEmail      String?
  source           String?
  status           String      @default("new")
  dealersSent      Int         @default(0)
  dealersAccepted  Int         @default(0)
  acceptedBy       String?
  carMake          String?
  carModel         String?
  carYear          Int?
  carTrim          String?
  carMsrp          Int?
  calcType         String?
  calcPayment      Int?
  calcDown         Int?
  calcTier         String?
  calcZip          String?
  calcMileage      String?
  calcTerm         String?
  payMethod        String?
  paymentName      String?
  isFirstTimeBuyer Boolean     @default(false)
  hasTradeIn       Boolean     @default(false)
  tradeInMake      String?
  tradeInModel     String?
  tradeInYear      Int?
  tradeInMileage   Int?
  tradeInVin       String?
  tradeInHasLoan   Boolean     @default(false)
  tradeInPayoff    Int?
  creditApp        String?
  userId           String?
  payload          String?
  depositStatus    String      @default("pending")
  depositAmount    Int?
  depositId        String?
  creditConsent    Boolean     @default(false)
  creditScore      Int?
  vin              String?
  createdAt        DateTime    @default(now())
  assignedToId     String?
  dealId           String?
  notes            String?
  brokerFeeCents   Int         @default(0)
  dealerReserveCents Int       @default(0)
  complaints       Complaint[]
  assignedTo       User?       @relation("AssignedLeads", fields: [assignedToId], references: [id])
  deal             DealRecord? @relation(fields: [dealId], references: [id])
  offers              LeadOffer[]
  payments            Payment[]
  creditChecks        CreditCheck[]
  dealerAssignments   DealerAssignment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
  @@index([dealId])
}

model Payment {
  id                    String    @id @default(uuid())
  leadId                String?
  lead                  Lead?     @relation(fields: [leadId], references: [id])
  userId                String?
  quoteId               String?
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  amountCents           Int
  currency              String    @default("usd")
  status                String    @default("pending")
  refundedAt            DateTime?
  refundReason          String?
  metadata              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([leadId])
  @@index([stripeSessionId])
  @@index([status])
}

model Complaint {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  dealerId  String?
  reason    String
  status    String   @default("open")
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model LeadOffer {
  id          String   @id @default(uuid())
  leadId      String
  dealerId    String
  status      String   @default("pending")
  message     String?
  payment     Int?
  down        Int?
  alternative String?
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id        String   @id @default("default")
  key       String?  @unique @default(uuid())
  value     String?
  data      String?
  updatedAt DateTime @updatedAt
}

model DealRecord {
  id                       String   @id @default(uuid())
  type                     String   @default("legacy")
  ingestionId              String?  @unique
  publishStatus            String   @default("draft")
  reviewStatus             String   @default("pending")
  financialData            String?
  programKeys              String?
  eligibility              String?
  isFirstTimeBuyerEligible Boolean? @default(false)
  lenderId                 String?
  payload                  String   @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @default(now()) @updatedAt
  brokerFeeCents           Int      @default(0)
  customUrl                String?  @unique
  dealerReserveCents       Int      @default(0)
  profitCents              Int      @default(0)
  seoDescription           String?
  seoTitle                 String?
  lender                   Lender?  @relation(fields: [lenderId], references: [id])
  
  // Lifecycle Management
  expirationDate           DateTime?
  isSoldOut                Boolean  @default(false)
  
  // Marketing & Storefront
  tags                     String?  // JSON array of tags e.g. ["Special Offer", "1 Left"]
  isPinned                 Boolean  @default(false)
  
  // Analytics & Performance
  viewCount                Int      @default(0)
  leadCount                Int      @default(0)
  
  // Team & Workflow
  dealerNotes              String?  // Internal note about which dealer/manager provided this
  leads                    Lead[]

  @@index([publishStatus])
  @@index([lenderId])
  @@index([createdAt])
  @@index([type])
}

model Review {
  id         String   @id @default(uuid())
  clientName String?
  carName    String?
  location   String?
  imageUrl   String?
  videoUrl   String?
  savings    String?
  rating     Int
  comment    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Feedback {
  id        String   @id @default(uuid())
  name      String?
  email     String?
  message   String?
  content   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model ProgramBatch {
  id               String        @id @default(uuid())
  status           String        @default("DRAFT")
  isValid          Boolean       @default(false)
  validationErrors String?
  importedAt       DateTime      @default(now())
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  programs         BankProgram[]
  quotes           Quote[]
}

model BankProgram {
  id          String       @id @default(uuid())
  batchId     String
  lenderId    String?
  programType String
  make        String
  model       String
  trim        String
  year        Int
  term        Int
  mileage     Int?
  rv          Float?
  mf          Float?
  apr         Float?
  rebates     Int          @default(0)
  batch       ProgramBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  lender      Lender?      @relation(fields: [lenderId], references: [id])

  @@index([batchId, lenderId, programType, make, model, year, trim, term, mileage])
}

model DealerPartner {
  id          String             @id @default(uuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?
  slaHours    Int?               @default(24)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  adjustments DealerAdjustment[]
  assignments DealerAssignment[]
}

model DealerAdjustment {
  id              String         @id @default(uuid())
  make            String?
  model           String?
  trim            String?
  amount          Int
  isActive        Boolean        @default(true)
  startsAt        DateTime       @default(now())
  endsAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  dealerPartnerId String?
  dealerPartner   DealerPartner? @relation(fields: [dealerPartnerId], references: [id])

  @@index([make, model, isActive, startsAt, endsAt])
}

model ProgramOverride {
  id              String         @id @default(uuid())
  bankId          String?
  make            String?
  model           String?
  mfMarkup        Float?
  aprMarkup       Float?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PromoAIPost {
  id              String   @id @default(uuid())
  dealId          String
  make            String
  model           String
  trim            String
  discountPercent Float
  telegramText    String
  facebookText    String
  imageUrl        String?
  status          String   @default("pending") // pending, published, rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  discountAmount Int
  discountType   String    @default("FIXED")
  isActive       Boolean   @default(true)
  uses           Int       @default(0)
  maxUses        Int?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model BlogPost {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  content        String
  excerpt        String?
  authorId       String?
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  imageUrl       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Quote {
  id               String        @id @default(uuid())
  userId           String?
  leadId           String?
  lenderId         String?
  programBatchId   String?
  programType      String
  make             String
  model            String
  trim             String
  year             Int
  term             Int
  mileage          Int?
  msrp             Int
  sellingPrice     Int
  downPayment      Int
  mf               Float?
  apr              Float?
  residual         Float?
  rebates          Int           @default(0)
  dealerAdjustment Int           @default(0)
  finalPayment     Int
  createdAt        DateTime      @default(now())
  lender           Lender?       @relation(fields: [lenderId], references: [id])
  batch            ProgramBatch? @relation(fields: [programBatchId], references: [id])
}

model CreditCheck {
  id                  String    @id @default(uuid())
  leadId              String?
  lead                Lead?     @relation(fields: [leadId], references: [id])
  userId              String?
  consentGiven        Boolean   @default(false)
  consentTimestamp     DateTime?
  status              String    @default("pending")
  scoreRange          String?
  creditBand          String?
  rawResponse         String?
  normalizedProfile   String?
  errorMessage        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([leadId])
  @@index([status])
}

model DealerAssignment {
  id               String         @id @default(uuid())
  leadId           String
  lead             Lead           @relation(fields: [leadId], references: [id])
  dealerPartnerId  String
  dealerPartner    DealerPartner  @relation(fields: [dealerPartnerId], references: [id])
  staffId          String?
  status           String         @default("pending")
  slaDeadline      DateTime?
  comment          String?
  counterOffer     String?
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([leadId])
  @@index([dealerPartnerId])
  @@index([status])
}

model NotificationLog {
  id           String    @id @default(uuid())
  userId       String?
  channel      String
  templateKey  String?
  recipient    String
  subject      String?
  body         String?
  status       String    @default("pending")
  error        String?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  key       String   @unique
  channel   String
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleMake {
  id        String         @id @default(uuid())
  name      String         @unique
  isActive  Boolean        @default(true)
  models    VehicleModel[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model VehicleModel {
  id        String        @id @default(uuid())
  makeId    String
  make      VehicleMake   @relation(fields: [makeId], references: [id], onDelete: Cascade)
  name      String
  years     Int[]
  imageUrl  String?
  isActive  Boolean       @default(true)
  trims     VehicleTrim[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([makeId, name])
}

model VehicleTrim {
  id             String       @id @default(uuid())
  modelId        String
  model          VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  name           String
  msrpCents      Int          @default(0)
  baseMF         Float        @default(0)
  baseAPR        Float        @default(0)
  rv36           Float        @default(0)
  leaseCashCents Int          @default(0)
  photoLinks     String?      // JSON array of MarketCheck photo URLs
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([modelId, name])
}
