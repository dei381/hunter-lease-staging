{
  "manifest_version": 3,
  "name": "Hunter Lease Auditor",
  "version": "1.0",
  "description": "Real-time lease deal analysis on dealer websites.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.bmwusa.com/*", "*://*.mercedes-benz.com/*", "*://*.audiusa.com/*"],
      "js": ["content.js"]
    }
  ]
}
