rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /leads/{leadId}/documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }
    
    match /car-photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null; // Ideally check for admin role
    }
  }
}
